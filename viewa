<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Video Screen Grid Tester</title>
    <style>
        /* CSS Variables */
        :root {
            --bg-color: #1e1e2f;
            --text-color: #ffffff;
            --panel-bg: #2a2a40;
            --primary: #00d2ff;
            --primary-hover: #3a7bd5;
            --danger: #ff4b2b;
            --danger-hover: #ff416c;
            --border-radius: 8px;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-color);
            margin: 0;
            padding: 20px;
        }

        /* Control Panel */
        .control-panel {
            background-color: var(--panel-bg);
            padding: 20px;
            border-radius: var(--border-radius);
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
            margin-bottom: 20px;
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            align-items: center;
            justify-content: center;
        }

        .input-group {
            display: flex;
            flex-direction: column;
            gap: 5px;
        }

        label {
            font-size: 0.9rem;
            color: #ccc;
        }

        input {
            padding: 10px;
            border: 1px solid #444;
            border-radius: 4px;
            background-color: #1a1a24;
            color: white;
            min-width: 250px;
        }

        input[type="number"] {
            min-width: 100px;
        }

        input:focus {
            outline: none;
            border-color: var(--primary);
        }

        button {
            padding: 10px 20px;
            border: none;
            border-radius: 4px;
            font-weight: bold;
            cursor: pointer;
            color: white;
            transition: 0.3s ease;
            margin-top: 20px;
        }

        .btn-start {
            background: linear-gradient(to right, #00d2ff, #3a7bd5);
        }

        .btn-start:hover {
            opacity: 0.9;
            transform: scale(1.05);
        }

        .btn-stop {
            background: linear-gradient(to right, #ff416c, #ff4b2b);
        }

        .btn-stop:hover {
            opacity: 0.9;
            transform: scale(1.05);
        }

        /* Grid Container for Screens */
        .screens-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 15px;
            width: 100%;
        }

        .screen-wrapper {
            background: #000;
            border-radius: var(--border-radius);
            overflow: hidden;
            aspect-ratio: 16 / 9; /* ভিডিওর জন্য পারফেক্ট রেশিও */
            border: 2px solid #444;
            position: relative;
        }

        .screen-number {
            position: absolute;
            top: 5px;
            left: 5px;
            background: rgba(0, 0, 0, 0.7);
            color: white;
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 0.8rem;
            z-index: 10;
        }

        iframe {
            width: 100%;
            height: 100%;
            border: none;
        }
    </style>
</head>
<body>

    <!-- Control Panel -->
    <div class="control-panel">
        <div class="input-group">
            <label for="urlInput">ভিডিও বা ওয়েবসাইটের লিংক (URL)</label>
            <input type="text" id="urlInput" placeholder="https://www.facebook.com/share/r/..." required>
        </div>

        <div class="input-group">
            <label for="countInput">কয়টি স্ক্রিন বানাবেন?</label>
            <input type="number" id="countInput" min="1" max="100" value="4">
        </div>

        <button class="btn-start" id="startBtn">Start (স্ক্রিন তৈরি করুন)</button>
        <button class="btn-stop" id="stopBtn">Clear (সব মুছুন)</button>
    </div>

    <!-- Container where all screens will appear -->
    <div class="screens-container" id="screensContainer">
        <!-- Iframes will be injected here via JavaScript -->
    </div>

    <script>
        const startBtn = document.getElementById('startBtn');
        const stopBtn = document.getElementById('stopBtn');
        const urlInput = document.getElementById('urlInput');
        const countInput = document.getElementById('countInput');
        const container = document.getElementById('screensContainer');

        // ইউটিউব এবং ফেসবুক লিংক হলে সেটিকে Embed লিংকে কনভার্ট করার ফাংশন
        function getEmbedUrl(url) {
            let embedUrl = url;
            
            // ইউটিউবের সাধারণ লিংক বা শর্ট লিংক চেক করা
            if (url.includes("youtube.com/watch?v=")) {
                const videoId = url.split("v=")[1].split("&")[0];
                embedUrl = `https://www.youtube.com/embed/${videoId}?autoplay=1&mute=1`;
            } else if (url.includes("youtu.be/")) {
                const videoId = url.split("youtu.be/")[1].split("?")[0];
                embedUrl = `https://www.youtube.com/embed/${videoId}?autoplay=1&mute=1`;
            } 
            // ফেসবুক ভিডিও বা রিলস লিংক চেক করা
            else if (url.includes("facebook.com") || url.includes("fb.watch")) {
                // ফেসবুকের ভিডিওগুলোর জন্য বিশেষ প্লাগইন লিংক তৈরি করতে হয় এবং autoplay=true যুক্ত করা হয়েছে
                embedUrl = `https://www.facebook.com/plugins/video.php?href=${encodeURIComponent(url)}&show_text=false&width=auto&autoplay=true`;
            }
            
            return embedUrl;
        }

        // Start Button Logic
        startBtn.addEventListener('click', () => {
            const rawUrl = urlInput.value.trim();
            const count = parseInt(countInput.value, 10);

            if (!rawUrl) {
                alert("দয়া করে একটি লিংক প্রদান করুন!");
                return;
            }

            if (count < 1 || count > 100) {
                alert("১ থেকে ১০০ এর মধ্যে স্ক্রিন সংখ্যা দিন।");
                return;
            }

            // আগের স্ক্রিনগুলো মুছে ফেলা (যদি থাকে)
            container.innerHTML = '';

            // লিংকের ধরন অনুযায়ী সঠিক লিংক তৈরি
            const finalUrl = getEmbedUrl(rawUrl);

            // লুপ চালিয়ে যতগুলো বলা হয়েছে ততগুলো স্ক্রিন (iframe) তৈরি করা
            for (let i = 1; i <= count; i++) {
                // Wrapper Div
                const wrapper = document.createElement('div');
                wrapper.className = 'screen-wrapper';
                
                // ফেসবুক রিলস সাধারণত লম্বালম্বি (9:16) হয়, তাই স্টাইল এডজাস্টমেন্ট
                if(finalUrl.includes("facebook.com/plugins/video.php")) {
                    wrapper.style.aspectRatio = "auto";
                    wrapper.style.minHeight = "400px";
                }

                // Screen Number Badge
                const badge = document.createElement('div');
                badge.className = 'screen-number';
                badge.innerText = `Screen ${i}`;

                // Iframe (The mini browser/video player)
                const iframe = document.createElement('iframe');
                iframe.src = finalUrl;
                // ফেসবুক ভিডিওর জন্য প্রয়োজনীয় পারমিশন (autoplay যুক্ত করা আছে)
                iframe.allow = "autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share";
                iframe.allowFullscreen = true;
                iframe.style.border = "none";
                iframe.style.overflow = "hidden";

                // Append everything to container
                wrapper.appendChild(badge);
                wrapper.appendChild(iframe);
                container.appendChild(wrapper);
            }
        });

        // Clear Button Logic
        stopBtn.addEventListener('click', () => {
            container.innerHTML = ''; // সমস্ত স্ক্রিন মুছে ফেলবে
        });
    </script>
</body>
</html>
